<%- include('./partials/header') %>

<div class="w-full min-h-screen bg-gray-50 font-['helvetica_now_display']">
    <div class="max-w-7xl mx-auto px-10 py-16 flex flex-col lg:flex-row gap-12">
        
        <div class="w-full lg:w-[65%]">
            <h1 class="text-3xl font-bold mb-10 text-zinc-900 tracking-tight">Shopping Bag</h1>
            
            <% user.cart.forEach(function(item){ %>
                <div class="flex items-center gap-8 bg-white p-8 rounded-2xl shadow-[0_10px_40px_-15px_rgba(0,0,0,0.05)] mb-6 border border-zinc-100 transition-all hover:shadow-md">
                    
                    <div style="background-color: <%= item.bgColor %>;" 
                         class="w-40 h-40 flex items-center justify-center rounded-xl overflow-hidden shrink-0 shadow-inner">
                        <img class="h-32 object-contain drop-shadow-xl transform hover:scale-110 transition-transform duration-500" 
                             src="data:image/jpeg;base64, <%= item.image ? item.image.toString('base64') : '' %>" 
                             alt="<%= item.name %>">
                    </div>
                    
                    <div class="flex-grow flex flex-col justify-between h-40">
                        <div class="flex justify-between items-start">
                            <div class="space-y-1">
                                <h3 class="text-xl font-bold text-zinc-800"><%= item.name %></h3>
                                <p class="text-sm text-zinc-400 font-medium tracking-wide uppercase">Premium Quality</p>
                            </div>
                            
                            <div class="flex items-center bg-zinc-100 rounded-full px-3 py-1 gap-4">
                                <button class="w-6 h-6 flex items-center justify-center text-zinc-500 hover:text-zinc-900"><i class="ri-subtract-line text-sm"></i></button>
                                <span class="text-sm font-bold text-zinc-800">1</span>
                                <button class="w-6 h-6 flex items-center justify-center text-zinc-500 hover:text-zinc-900"><i class="ri-add-line text-sm"></i></button>
                            </div>
                        </div>

                        <div class="flex justify-between items-end">
                            <div class="flex gap-3">
                                <div style="background-color: <%= item.panelColor %>; color: <%= item.textColor %>;" 
                                     class="px-4 py-1.5 rounded-full text-xs font-bold tracking-widest uppercase">
                                    Product Info
                                </div>
                                <div style="background-color: <%= item.textColor %>;" 
                                     class="px-4 py-1.5 rounded-full text-white text-xs font-bold tracking-widest uppercase opacity-90">
                                    ₹ <%= Number(item.price) + 20 - Number(item.discount) %>
                                </div>
                            </div>
                            
                            <button class="text-zinc-300 hover:text-red-500 transition-colors">
                                <i class="ri-delete-bin-6-line text-xl"></i>
                            </button>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <div class="w-full lg:w-[35%]">
            <div class="bg-white rounded-3xl p-10 border border-zinc-100 shadow-[0_20px_50px_-20px_rgba(0,0,0,0.08)] sticky top-10">
                <h2 class="text-2xl font-bold text-zinc-900 mb-8">Summary</h2>
                
                <% 
                    let totalMRP = 0; 
                    let totalDiscount = 0; 
                    user.cart.forEach(function(item) { 
                        totalMRP += Number(item.price);
                        totalDiscount += Number(item.discount);
                    }); 
                %>

                <div class="space-y-5">
                    <div class="flex justify-between items-center text-zinc-500">
                        <span class="font-medium">Total Price</span>
                        <span class="text-zinc-900 font-bold">₹ <%= totalMRP %></span>
                    </div>
                    <div class="flex justify-between items-center text-zinc-500">
                        <span class="font-medium">Discount</span>
                        <span class="text-red-500 font-bold">- ₹ <%= totalDiscount %></span>
                    </div>
                    <div class="flex justify-between items-center text-zinc-500">
                        <span class="font-medium">Shipping</span>
                        <span class="text-green-600 font-bold uppercase text-xs tracking-widest">Free</span>
                    </div>
                    <div class="flex justify-between items-center text-zinc-500">
                        <span class="font-medium">Platform Fee</span>
                        <span class="text-zinc-900 font-bold">₹ 20</span>
                    </div>

                    <div class="h-px bg-zinc-100 w-full my-4"></div>

                    <div class="flex justify-between items-center pb-8">
                        <span class="text-lg font-bold text-zinc-900">Total Amount</span>
                        <span class="text-3xl font-black text-zinc-900 tracking-tighter">₹ <%= bill %></span>
                    </div>

                    <button class="w-full bg-black text-white text-sm font-bold py-5 rounded-2xl shadow-xl shadow-zinc-200 hover:bg-zinc-800 transition-all active:scale-95 uppercase tracking-[0.2em]">
                        Checkout
                    </button>
                    
                    <p class="text-center text-zinc-400 text-xs mt-6 font-medium">Safe & Secure Payment</p>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('./partials/footer') %>